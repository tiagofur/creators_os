# =============================================================================
# Creators OS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Public (exposed to the browser via NEXT_PUBLIC_ prefix)
# ---------------------------------------------------------------------------

# Base URL for the REST API backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Sentry DSN for client-side error reporting (optional — omit to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Canonical app URL (used for OG tags, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Server-only (never sent to the browser)
# ---------------------------------------------------------------------------

# Sentry DSN for server-side / edge error reporting (optional — omit to disable)
SENTRY_DSN=

# Sentry organisation slug (required for source map uploads during build)
SENTRY_ORG=

# Sentry project slug (required for source map uploads during build)
SENTRY_PROJECT=

# ---------------------------------------------------------------------------
# Build-time flags
# ---------------------------------------------------------------------------

# Set to "true" to enable @next/bundle-analyzer output
ANALYZE=
