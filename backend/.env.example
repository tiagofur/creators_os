# =============================================================================
# Ordo Creator OS — Backend Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Server ---
SERVER_PORT=8080
APP_ENV=development          # development | staging | production

# --- Logging ---
LOG_LEVEL=info               # debug | info | warn | error
LOG_FORMAT=text              # json | text (text is human-readable, dev only)

# --- PostgreSQL ---
# Full DSN (preferred, 12-factor):
DATABASE_URL=postgres://ordo:ordo_dev_password@localhost:5432/ordo_dev?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Metrics ---
METRICS_PORT=9090

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- AI Providers ---
AI_CLAUDE_API_KEY=sk-ant-...
AI_OPENAI_API_KEY=sk-...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Security ---
AES_ENCRYPTION_KEY=32-byte-hex-encoded-key-here
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem

# --- Storage Backend: minio | s3 ---
STORAGE_BACKEND=minio

# --- MinIO (local dev) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ordo_minio
MINIO_SECRET_KEY=ordo_minio_secret
MINIO_BUCKET=ordo-uploads

# --- AWS S3 (staging/production) ---
AWS_S3_BUCKET=ordo-uploads-prod
AWS_REGION=us-east-1
# AWS credentials are loaded from the default credential chain:
# env vars AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, or ~/.aws/credentials,
# or EC2/ECS instance role.
